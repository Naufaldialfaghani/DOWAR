{
    "openapi": "3.0.0",
    "info": {
        "title": "DOWAR API",
        "description": "API Donasi & Feedback System",
        "version": "1.0.0"
    },
    "servers": [
        {
            "url": "http://localhost:8000",
            "description": "Local Server"
        },
        {
            "url": "http://localhost:8000/api",
