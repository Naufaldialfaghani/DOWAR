                "summary": "Lihat semua program donasi (Publik)",
                "operationId": "f63bfb37edf1acfd021c50961b734ec0",
                "responses": {
                    "200": {
                        "description": "Berhasil mengambil data"
                    }
                }
            },
            "post": {
                "tags": [
                    "Campaigns"
                ],
                "summary": "Buat program donasi baru (Hanya Admin)",
                "operationId": "272d9b28b56c8e18d5ef4c7440a05def",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "properties": {
                                    "title": {
                                        "type": "string",
                                        "example": "Bantuan Pakaian Malang"
                                    },
                                    "description": {
                                        "type": "string",
                                        "example": "Donasi pakaian layak pakai."
                                    },
                                    "target_date": {
                                        "type": "string",
                                        "format": "date",
                                        "example": "2026-07-25"
