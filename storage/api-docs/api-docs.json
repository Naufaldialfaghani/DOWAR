                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "properties": {
                                    "name": {
                                        "type": "string",
                                        "example": "Panti Asuhan Baru"
                                    },
                                    "address": {
                                        "type": "string",
                                        "example": "Jl. Baru No. 5, Malang"
                                    },
                                    "phone": {
                                        "type": "string",
                                        "example": "08987654321"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Berhasil diupdate"
                    },
                    "404": {
                        "description": "Data tidak ditemukan"
                    }
                }
            },
            "delete": {
                "tags": [
                    "Beneficiaries"
                ],
                "summary": "Hapus penerima manfaat",
                "operationId": "566d4c0e504b36904d69f8b1b9d9ca35",
