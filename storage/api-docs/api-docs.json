    "paths": {
        "/api/auth/register": {
            "post": {
                "tags": [
                    "Authentication"
                ],
                "summary": "Register akun baru",
                "operationId": "d764dd091cc4494ae0baf360b03319f3",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "properties": {
                                    "name": {
                                        "type": "string",
                                        "example": "Naufaldi Admin"
                                    },
                                    "email": {
                                        "type": "string",
                                        "example": "naufaldi@dowar.com"
                                    },
                                    "password": {
                                        "type": "string",
                                        "example": "password123"
                                    },
                                    "role": {
                                        "type": "string",
                                        "example": "admin"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Register Sukses"
                    }
                }
            }
        },
        "/api/auth/login": {
            "post": {
                "tags": [
                    "Authentication"
                ],
                "summary": "Login dan dapatkan Token JWT",
                "operationId": "8dcb70df1020986038d098cc08d05dae",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "properties": {
                                    "email": {
                                        "type": "string",
                                        "example": "naufaldi@dowar.com"
                                    },
                                    "password": {
                                        "type": "string",
                                        "example": "password123"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Login Sukses"
                    },
                    "401": {
                        "description": "Kredensial Salah"
                    }
                }
            }
        },
        "/api/beneficiaries": {
            "get": {
                "tags": [
                    "Beneficiaries"
                ],
                "summary": "Tampilkan semua penerima manfaat",
                "operationId": "0c3c61f1ece70ef76bb1a8ee7a8e7223",
                "responses": {
                    "200": {
                        "description": "Success"
                    }
                }
            },
            "post": {
                "tags": [
                    "Beneficiaries"
                ],
                "summary": "Tambah penerima manfaat baru",
                "operationId": "957c4f28a4f5dfbae60159df0ad2ac2c",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "name",
                                    "address",
                                    "phone"
                                ],
                                "properties": {
                                    "name": {
                                        "type": "string",
                                        "example": "Panti Asuhan Harapan Bangsa"
                                    },
                                    "address": {
                                        "type": "string",
                                        "example": "Jl. Merdeka No. 10, Malang"
                                    },
                                    "phone": {
                                        "type": "string",
                                        "example": "08123456789"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Berhasil ditambahkan"
                    },
                    "422": {
                        "description": "Validasi gagal"
                    }
                }
            }
        },
        "/api/beneficiaries/{id}": {
            "put": {
                "tags": [
                    "Beneficiaries"
                ],
                "summary": "Update data penerima manfaat",
                "operationId": "260cac28769eec986bc7fed679adfc2f",
                "parameters": [
